<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LinguoCore Pro | Interface UX v3</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            /* PALETA DE CONTRASTE REFINADA */
            --bg-sidebar: #1a3a32;      /* Verde Bosque Medio (Diferenciación clara) */
            --bg-main: #000000;         /* Negro Profundo */
            --accent: #00ff66;          /* Verde Neón */
            --accent-emerald: #10b981;  /* Verde Esmeralda para degradados */
            --accent-muted: rgba(0, 255, 102, 0.1);
            --text-main: #e0e0e0;
            --text-bright: #ffffff;
            --sidebar-text: #b8d1ca;
            --sidebar-width: 320px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            display: flex;
            overflow-x: hidden;
            scroll-behavior: smooth;
        }

        /* --- SIDEBAR (ZONA CLARA REFINADA) --- */
        aside {
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--bg-sidebar);
            position: fixed;
            left: 0; top: 0;
            padding: 60px 40px;
            border-right: 2px solid var(--accent);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 10px 0 30px rgba(0,0,0,0.4);
        }

        /* LÓGICA DE OCULTADO */
        .sidebar-hidden aside {
            transform: translateX(-100%);
        }

        /* BOTONES DE CONTROL (NUEVOS) */
        .toggle-btn {
            background: var(--accent);
            color: black;
            border: none;
            padding: 10px 15px;
            font-weight: 900;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s;
            margin-bottom: 30px;
            align-self: flex-start;
        }

        .toggle-btn:hover {
            box-shadow: 0 0 15px var(--accent);
            transform: scale(1.05);
        }

        .open-menu-btn {
            position: fixed;
            top: 20px;
            left: -150px; /* Escondido por defecto */
            z-index: 999;
            transition: left 0.5s ease;
        }

        .sidebar-hidden .open-menu-btn {
            left: 20px; /* Aparece cuando el menú se oculta */
        }

        .logo {
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--text-bright);
            letter-spacing: -2px;
            margin-bottom: 50px;
        }
        .logo span { color: var(--accent); }

        .nav-menu { list-style: none; }
        .nav-menu li { margin-bottom: 25px; }

        .nav-menu a {
            text-decoration: none;
            color: var(--sidebar-text);
            font-size: 0.85rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: inline-block;
        }

        .nav-menu a:hover, .nav-menu a.active {
            color: var(--accent);
            transform: translateX(10px) scale(1.05);
            text-shadow: 0 0 10px var(--accent);
        }

        /* --- CONTENIDO PRINCIPAL --- */
        main {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            padding: 0 100px;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .sidebar-hidden main {
            margin-left: 0;
            width: 100%;
            padding: 0 15%;
        }

        section {
            min-height: 100vh;
            padding: 140px 0;
            display: flex;
            flex-direction: column;
            justify-content: center;
            opacity: 0;
            transform: translateY(20px);
            transition: 0.8s ease-out;
            position: relative;
        }

        section.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* RAYA DELIMITADORA SUAVE Y DIFUMINADA */
        .divider {
            width: 100%;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(0, 255, 102, 0.2) 20%, rgba(0, 255, 102, 0.2) 80%, transparent);
            margin-top: 100px;
            box-shadow: 0 0 10px rgba(0, 255, 102, 0.05);
        }

        .tag {
            color: var(--accent);
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 5px;
            font-size: 0.7rem;
            margin-bottom: 20px;
        }

        h2 {
            font-size: clamp(3.5rem, 7vw, 6.5rem);
            color: var(--text-bright);
            font-weight: 900;
            line-height: 0.85;
            margin-bottom: 40px;
            letter-spacing: -4px;
        }
        
        h2 span { 
            background: linear-gradient(135deg, var(--accent), var(--accent-emerald));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            color: var(--accent);
        }

        .description {
            font-size: 1.4rem;
            line-height: 1.7;
            max-width: 850px;
            margin-bottom: 50px;
            color: #aaa;
        }

        .feature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        .feature-card {
            background: #080808;
            border: 1px solid #1a1a1a;
            padding: 40px;
            border-radius: 20px;
            transition: all 0.4s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .feature-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at top right, var(--accent-muted), transparent);
            opacity: 0;
            transition: 0.4s;
        }

        .feature-card:hover {
            border-color: var(--accent);
            transform: translateY(-8px);
            background: #0d1a14;
            box-shadow: 0 15px 30px rgba(0, 255, 102, 0.08);
        }

        .feature-card:hover::before { opacity: 1; }

        .feature-card h4 {
            color: var(--accent);
            font-size: 1.5rem;
            margin-bottom: 15px;
            font-weight: 800;
        }

        .feature-card p {
            font-size: 1rem;
            line-height: 1.6;
            color: #999;
            transition: 0.3s;
        }

        .feature-card:hover p { color: var(--text-bright); }

        /* SIMULADOR */
        .sim-box {
            background: #050505;
            border: 2px solid #222;
            border-radius: 30px;
            padding: 60px;
            transition: 0.5s;
        }
        .sim-box:focus-within {
            border-color: var(--accent);
            box-shadow: 0 0 40px rgba(0,255,102,0.15);
        }

        .btn-glow {
            background: var(--accent);
            color: black;
            border: none;
            padding: 22px;
            width: 100%;
            font-weight: 900;
            font-size: 1.1rem;
            border-radius: 12px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 30px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .btn-glow:hover {
            box-shadow: 0 0 25px var(--accent);
            transform: scale(1.01);
        }

        footer {
            padding: 100px 0;
            border-top: 1px solid #1a1a1a;
        }

        @media (max-width: 1100px) {
            aside { width: 90px; padding: 40px 15px; }
            aside .nav-menu span, aside .logo span { display: none; }
            main { margin-left: 90px; width: calc(100% - 90px); padding: 0 30px; }
            h2 { font-size: 3rem; }
        }
    </style>
</head>
<body id="main-body">

    <button class="toggle-btn open-menu-btn" onclick="toggleSidebar()">☰ Abrir Menú</button>

    <aside id="sidebar">
        <button class="toggle-btn" onclick="toggleSidebar()">✕ Ocultar Menú</button>

        <div class="logo">L<span>C</span></div>
        <nav>
            <ul class="nav-menu">
                <li><a href="#vision" class="active"><span>Vision</span></a></li>
                <li><a href="#ingenieria"><span>Engineering</span></a></li>
                <li><a href="#experiencia"><span>Real Cases</span></a></li>
                <li><a href="#especificaciones"><span>Specs</span></a></li>
                <li><a href="#simulador"><span>Live Demo</span></a></li>
            </ul>
        </nav>
        <div style="margin-top: auto; color: var(--accent); font-weight: 900; font-size: 0.7rem;">
            LC-PRO // V.3.26
        </div>
    </aside>

    <main>
        <section id="vision">
            <span class="tag">// Global Philosophy</span>
            <h2>Voz sin <span>fronteras.</span></h2>
            <p class="description">
                LinguoCore nace de la necesidad detectada en miles de usuarios que, como <b>Diego (19 años)</b>, sienten que incluso dominando idiomas como el inglés, la conexión real se pierde al no hablar la lengua nativa del interlocutor. No vendemos cascos; vendemos empatía instantánea.
            </p>
            <div class="divider"></div>
        </section>

        <section id="ingenieria">
            <span class="tag">// Hard-Tech Solution</span>
            <h2>Ingeniería <span>L1-Quantum.</span></h2>
            <div class="feature-grid">
                <div class="feature-card">
                    <h4>Micro-Latencia</h4>
                    <p>Reducción del tiempo de respuesta a 0.12 segundos. El flujo de datos es procesado por un núcleo dedicado que elimina la "pausa del traductor" tradicional.</p>
                </div>
                <div class="feature-card">
                    <h4>Clonación Tímbrica</h4>
                    <p>Nuestra IA no usa voces robóticas. Analiza los armónicos de quien habla y reconstruye la frase en tu idioma manteniendo su carisma y tono de voz original.</p>
                </div>
            </div>
            <div class="divider"></div>
        </section>

        <section id="experiencia">
            <span class="tag">// Solving Real Needs</span>
            <h2>Impacto <span>Humano.</span></h2>
            <p class="description">Hemos diseñado LinguoCore para resolver problemas reales extraídos de nuestro estudio de campo:</p>
            <div class="feature-grid">
                <div class="feature-card">
                    <h4>Entorno Laboral</h4>
                    <p>Como el caso de <b>Juan (52 años)</b>, que temía perder ascensos por la barrera del idioma. LinguoCore permite liderar reuniones internacionales con total seguridad.</p>
                </div>
                <div class="feature-card">
                    <h4>Turismo y Comercio</h4>
                    <p>Ayudamos a personas como <b>Laura (40 años)</b> a atender clientes extranjeros en segundos, eliminando la frustración de usar el móvil entre medias.</p>
                </div>
                <div class="feature-card">
                    <h4>Estudiantes Erasmus</h4>
                    <p>Para aquellos que, como <b>Ana (21 años)</b>, dudan de sus capacidades académicas en otro país. LinguoCore traduce clases magistrales en tiempo real.</p>
                </div>
            </div>
            <div class="divider"></div>
        </section>

        <section id="especificaciones">
            <span class="tag">// Hardware Specs</span>
            <h2>Poder <span>Puro.</span></h2>
            <div class="feature-grid">
                <div class="feature-card">
                    <h4>Batería de Grafeno</h4>
                    <p>30 horas de uso continuo. Carga por inducción magnética en solo 12 minutos.</p>
                </div>
                <div class="feature-card">
                    <h4>Titanio Grado 5</h4>
                    <p>Chasis ultra-ligero de alta resistencia. Diseñado para no generar fatiga tras 8 horas de uso.</p>
                </div>
                <div class="feature-card">
                    <h4>Diccionario Offline</h4>
                    <p>Memoria interna de 128GB para almacenar paquetes de idiomas completos sin depender de la nube.</p>
                </div>
            </div>
            <div class="divider"></div>
        </section>

        <section id="simulador">
            <span class="tag">// Simulation Mode</span>
            <h2>Prueba el <span>Motor.</span></h2>
            <div class="sim-box">
                <p style="margin-bottom: 20px; font-weight: 800; color: var(--accent);">CONFIGURACIÓN DE ESCENARIO:</p>
                <select id="lang-picker" style="width: 100%; padding: 20px; background: #111; color: white; border: 1px solid #333; border-radius: 12px; margin-bottom: 25px; font-size: 1rem;">
                    <option value="en">Negocios en Londres (Inglés)</option>
                    <option value="pl">Universidad en Polonia (Polaco)</option>
                    <option value="fr">Turismo en París (Francés)</option>
                </select>
                <button class="btn-glow" id="run-demo">ACTIVAR TRADUCCIÓN NEURAL</button>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 40px;">
                    <div style="background: rgba(255,255,255,0.03); padding: 25px; border-radius: 15px;">
                        <small style="color: var(--accent);">AUDICIÓN</small>
                        <p id="input-txt" style="margin-top: 10px; font-style: italic; opacity: 0.5;">Esperando voz...</p>
                    </div>
                    <div style="background: rgba(0, 255, 102, 0.05); padding: 25px; border-radius: 15px; border: 1px solid var(--accent-muted);">
                        <small style="color: var(--accent);">PROCESADO</small>
                        <p id="output-txt" style="margin-top: 10px; font-weight: 800;">---</p>
                    </div>
                </div>
            </div>
        </section>

        <footer>
            <h2>Linguo<span>Core</span></h2>
            <p style="margin-top: 20px;">Proyecto por Carlos Campos & Hugo Jiménez</p>
            <p style="font-size: 0.8rem; opacity: 0.3;">Grado en Ingeniería Informática - Salamanca 2026</p>
        </footer>
    </main>

    <script>
        // FUNCIÓN NUEVA PARA EL MENÚ
        function toggleSidebar() {
            document.getElementById('main-body').classList.toggle('sidebar-hidden');
        }

        // Efecto de aparición al hacer scroll (Intersection Observer)
        const observerOptions = { threshold: 0.15 };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    document.querySelectorAll('.nav-menu a').forEach(a => {
                        a.classList.remove('active');
                        if (a.getAttribute('href').substring(1) === entry.target.id) {
                            a.classList.add('active');
                        }
                    });
                }
            });
        }, observerOptions);

        document.querySelectorAll('section').forEach(section => observer.observe(section));

        // Lógica del Simulador
        const frases = {
            'en': { in: "The deployment of the new L1 chip architecture has reduced processing latency by forty percent.", out: "El despliegue de la nueva arquitectura del chip L1 ha reducido la latencia de procesamiento en un cuarenta por ciento." },
            'pl': { in: "Dzień dobry, chciałbym zapisać się na kurs programowania systemowego.", out: "Buenos días, me gustaría apuntarme al curso de programación de sistemas." },
            'fr': { in: "Où se trouve la sortie de secours la plus proche de l'amphithéâtre central?", out: "¿Dónde se encuentra la salida de emergencia más cercana al anfiteatro central?" }
        };

        const btn = document.getElementById('run-demo');
        btn.addEventListener('click', () => {
            const sel = document.getElementById('lang-picker').value;
            btn.textContent = "ESCUCHANDO...";
            btn.style.opacity = "0.7";
            
            setTimeout(() => {
                document.getElementById('input-txt').textContent = frases[sel].in;
                document.getElementById('output-txt').textContent = frases[sel].out;
                btn.textContent = "TRADUCCIÓN NEURAL COMPLETADA";
                btn.style.opacity = "1";
            }, 1000);
        });
    </script>
</body>
</html>
