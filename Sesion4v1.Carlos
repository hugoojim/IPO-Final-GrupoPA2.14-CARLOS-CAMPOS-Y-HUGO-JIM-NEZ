<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LinguoCore | Traducción en Tiempo Real</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-dark: #061210;
            --bg-darker: #040d0b;
            --glass-bg: rgba(10, 28, 26, 0.8);
            --text-primary: #f0fdf4;
            --text-secondary: #94a3a8;
            --accent-green: #4ade80;
            --accent-emerald: #10b981;
            --grad-linear: linear-gradient(135deg, var(--accent-green), var(--accent-emerald));
            --border-glass: rgba(74, 222, 128, 0.15);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-secondary);
            line-height: 1.6;
            scroll-behavior: smooth;
            overflow-x: hidden;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

        .divider {
            height: 1px;
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
            background: linear-gradient(90deg, transparent, var(--accent-green), transparent);
            opacity: 0.6;
        }

        /* HEADER */
        header {
            background: var(--glass-bg);
            backdrop-filter: blur(15px);
            position: fixed;
            width: 100%;
            top: 0; z-index: 1000;
            border-bottom: 1px solid var(--border-glass);
        }

        nav { height: 80px; display: flex; justify-content: space-between; align-items: center; }

        .logo { 
            font-size: 1.6rem; 
            font-weight: 900; 
            background: var(--grad-linear);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-links { display: flex; list-style: none; gap: 32px; }
        .nav-links a {
            text-decoration: none;
            color: var(--text-primary);
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            transition: 0.3s;
        }
        .nav-links a:hover { color: var(--accent-green); }

        /* HERO */
        .hero { padding: 220px 0 140px; text-align: center; }
        h1 { font-size: clamp(2.5rem, 8vw, 4.8rem); font-weight: 900; color: var(--text-primary); line-height: 0.95; margin-bottom: 28px; }
        h1 span { color: var(--accent-green); display: block; }

        /* SECCIONES GENERALES */
        .section-padding { padding: 100px 0; }
        h2.section-title { 
            text-align: center; font-size: 2.5rem; font-weight: 900;
            margin-bottom: 60px; color: var(--text-primary);
        }

        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; }

        /* TARJETAS NORMALES (NECESIDAD) */
        .card {
            background: rgba(255, 255, 255, 0.02);
            padding: 40px;
            border-radius: 24px;
            border: 1px solid var(--border-glass);
            transition: 0.4s;
        }

        /* =========================================
           ESTILOS DESTACADOS PARA TECNOLOGÍA
           ========================================= */
        .tech-section {
            background: radial-gradient(circle at center, rgba(16, 185, 129, 0.08) 0%, transparent 70%);
            position: relative;
        }

        .tech-card {
            background: rgba(10, 28, 26, 0.6);
            border: 1px solid rgba(74, 222, 128, 0.3);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            padding: 50px 40px;
            position: relative;
            overflow: hidden;
        }

        .tech-card:hover {
            border-color: var(--accent-green);
            box-shadow: 0 0 40px rgba(74, 222, 128, 0.15);
            transform: translateY(-10px);
        }

        .tech-number {
            position: absolute;
            top: -10px;
            right: 10px;
            font-size: 6rem;
            font-weight: 900;
            color: var(--accent-green);
            opacity: 0.05;
            user-select: none;
        }

        .tech-card h3 {
            font-size: 1.8rem;
            color: var(--accent-green);
            margin-bottom: 15px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .tech-card h3::before {
            content: "";
            width: 20px;
            height: 2px;
            background: var(--grad-linear);
        }

        /* SIMULADOR */
        .demo-container {
            background: #0a1c1a;
            padding: 50px;
            border-radius: 30px;
            border: 1px solid var(--accent-green);
        }

        .demo-ui { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 30px; }
        .bubble { padding: 25px; border-radius: 20px; background: rgba(0, 0, 0, 0.3); }
        .bubble small { color: var(--accent-green); font-weight: 900; display: block; margin-bottom: 8px; }

        select, .demo-btn { width: 100%; padding: 18px; border-radius: 12px; font-size: 1rem; }
        select { background: #132a27; color: white; border: 1px solid var(--border-glass); margin-bottom: 20px; outline: none; }
        .demo-btn { background: var(--grad-linear); color: #061210; border: none; font-weight: 900; cursor: pointer; }

        footer { padding: 60px 0; text-align: center; border-top: 1px solid var(--border-glass); }

        @media (max-width: 768px) {
            .demo-ui { grid-template-columns: 1fr; }
            .nav-links { display: none; }
        }
    </style>
</head>
<body>

    <header>
        <nav class="container">
            <div class="logo">Linguo<span>Core</span></div>
            <ul class="nav-links">
                <li><a href="#problema">Necesidad</a></li>
                <li><a href="#solucion">Tecnología</a></li>
                <li><a href="#demo">Simulador</a></li>
            </ul>
        </nav>
    </header>

    <main>
        <section class="hero container">
            <h1>Libertad total <span>sin fronteras.</span></h1>
            <p>Cascos inteligentes con IA que traducen cualquier conversación al instante.</p>
        </section>

        <div class="divider"></div>

        <section id="problema" class="section-padding">
            <div class="container">
                <h2 class="section-title">Nuestra Misión</h2>
                <div class="grid">
                    <article class="card">
                        <h3>Viajes sin límites</h3>
                        <p>Elimina el miedo a no entender las indicaciones o la cultura local.</p>
                    </article>
                    <article class="card">
                        <h3>Éxito Profesional</h3>
                        <p>Negocia en mercados internacionales con la fluidez de un nativo.</p>
                    </article>
                    <article class="card">
                        <h3>Inmersión Educativa</h3>
                        <p>Ideal para estudiantes internacionales que buscan una integración total.</p>
                    </article>
                </div>
            </div>
        </section>

        <div class="divider"></div>

        <section id="solucion" class="section-padding tech-section">
            <div class="container">
                <h2 class="section-title" style="font-size: 3.2rem;">Potencia Tecnológica</h2>
                <div class="grid">
                    <div class="card tech-card">
                        <span class="tech-number">01</span>
                        <h3>Detección 0.2s</h3>
                        <p>Nuestra red neuronal propietaria identifica idiomas y dialectos en milisegundos. Comunicación fluida, sin esperas, como si ambos hablarais el mismo idioma.</p>
                    </div>
                    <div class="card tech-card">
                        <span class="tech-number">02</span>
                        <h3>Voz Natural HD</h3>
                        <p>Olvídate de las voces robóticas. LinguoCore utiliza síntesis granular para replicar la entonación, el ritmo y la calidez de la voz humana original.</p>
                    </div>
                    <div class="card tech-card">
                        <span class="tech-number">03</span>
                        <h3>Neural ANC</h3>
                        <p>Algoritmos de cancelación activa de ruido que aislan las frecuencias de la voz humana, permitiendo traducciones nítidas incluso en aeropuertos o eventos masivos.</p>
                    </div>
                </div>
            </div>
        </section>

        <div class="divider"></div>

        <section id="demo" class="section-padding">
            <div class="container">
                <h2 class="section-title">Prueba la Experiencia</h2>
                <div class="demo-container">
                    <select id="lang-picker">
                        <option value="en">Inglés (UK) - Escenario: Aeropuerto</option>
                        <option value="fr">Francés - Escenario: Cafetería</option>
                        <option value="pl">Polaco - Escenario: Universidad</option>
                    </select>
                    <button class="demo-btn" id="run-demo">Simular Traducción</button>

                    <div class="demo-ui">
                        <div class="bubble">
                            <small>Voz externa</small>
                            <p id="input-txt" style="font-style: italic;">Selecciona un escenario...</p>
                        </div>
                        <div class="bubble" style="border: 1px solid var(--accent-green); background: rgba(74, 222, 128, 0.05);">
                            <small>Traducción LinguoCore</small>
                            <p id="output-txt" style="font-weight: 800; color: var(--text-primary);">---</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="container">
            <p><strong>PROYECTO ACADÉMICO IPO</strong> | Carlos Campos y Hugo Jiménez</p>
            <p style="margin-top: 10px; opacity: 0.4;">Grado en Ingeniería Informática - USAL 2026</p>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const btn = document.getElementById('run-demo');
            const inputDisplay = document.getElementById('input-txt');
            const outputDisplay = document.getElementById('output-txt');
            const langPicker = document.getElementById('lang-picker');

            const frases = {
                'en': { in: "Please, proceed to the security check at gate 5.", out: "Por favor, diríjase al control de seguridad en la puerta 5." },
                'fr': { in: "Bonjour, je voudrais un café au lait et un croissant.", out: "Hola, me gustaría un café con leche y un cruasán." },
                'pl': { in: "Gdzie znajduje się najbliższy wydział informatyki?", out: "¿Dónde se encuentra la facultad de informática más cercana?" }
            };

            btn.addEventListener('click', () => {
                const selected = langPicker.value;
                btn.textContent = "Procesando...";
                setTimeout(() => {
                    inputDisplay.textContent = frases[selected].in;
                    outputDisplay.textContent = frases[selected].out;
                    btn.textContent = "Simular Traducción";
                }, 800);
            });
        });
    </script>
</body>
</html>
